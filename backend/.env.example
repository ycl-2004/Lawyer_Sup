# 后端环境变量示例 —— 复制为 backend/.env 后按需修改（.env 已被 .gitignore 忽略，勿提交密钥）。
# 不配置任何变量也能跑：默认 mock 模式，离线、零外部依赖、规则抽取。

# ---- LLM（事实抽取增强；不配置则纯规则抽取，离线可用）----
# LLM_PROVIDER=mock 时不调用任何外部 API；设为 deepseek 后启用真实抽取（引用逐字校验）。
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
# 换 Qwen/DashScope 等 OpenAI 兼容服务：只改上面三项，业务代码不动。

# ---- 本地数据（实时案件 SQLite + 上传原件）----
# 默认存放于 backend/data/；删除该目录即清空全部本地数据。
# LAWDESK_DATA_DIR=./data
# 案件无活动自动清理天数（任何打开/编辑都会续期）。
LAWDESK_RETENTION_DAYS=14
